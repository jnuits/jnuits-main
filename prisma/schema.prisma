generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum UserRole {
  USER
  MEMBER
  EXECUTIVE
  SUB_EXECUTIVE
  ADMIN
  SUPER_ADMIN
}

enum RegistrationType {
  MEMBER_APPLY
  WORKSHOP
  BCC_COURSE
}

enum StatusType {
  APPROVED
  REJECTED
  PENDING
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// --- Models ---

model User {
  id            String    @id @map("_id")
  name          String?
  email         String?   @unique
  emailVerified Boolean   @default(false)
  image         String?

  role          UserRole  @default(USER)
  membershipId  String?  

  points        Int       @default(0)
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?

  studentId     String    @unique
  department    String
  batch         String?
  gender        String?

  phoneNumber   String
  showPhone     Boolean   @default(false)
  showEmail     Boolean   @default(false)

  twoFactorEnabled Boolean @default(false)
  secret           String?
  backupCodes      String?

  // Relations
  committees CommitteeMember[]
  registrations Registration[]
  payments      Payment[]
  projects      Project[]
  posts         Post[]
  accounts      Account[]
  sessions      Session[]
  twoFactor     TwoFactor?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Account {
  id                    String   @id @map("_id")
  userId                String
  accountId             String
  providerId            String
  provider              String?
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Session {
  id        String   @id @map("_id")
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Verification {
  id         String   @id @map("_id")
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model TwoFactor {
  id          String @id @map("_id")
  secret      String
  backupCodes String
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("twoFactor")
}

model Registration {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  
  userId       String?
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  

  status       StatusType       @default(PENDING)
  isPassed     Boolean?          
  eventId      String?          @db.ObjectId
  event        Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  Marks        Int?             @default(0)   
  vivaComment  String?         
  isAttended   Boolean          @default(false)
  metadata     Json?

  payments     Payment[]
  appliedAt    DateTime         @default(now())

  @@map("registrations")
}

model Event {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  fee           Int         @default(0)
  isPaid        Boolean       @default(false)
  type          RegistrationType @default(MEMBER_APPLY)
  description   String
  image         String
  deadline      DateTime
  isActive      Boolean
  isFeatured    Boolean       @default(false)       
  isPublic      Boolean  @default(false)
  totalApplicants Int     @default(0)

  createdAt     DateTime       @default(now())
  registrations Registration[]
  guestRegistrations GuestRegistration[]
  coupons     Coupon[]

  @@map("events")
}

model Project {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  title    String
  link     String?
  authorId String
  author   User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String
  image     String?
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@map("posts")
}

model Payment {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  amount         String
  transactionId  String        @unique
  provider       String?
  status         PaymentStatus @default(PENDING)

  userId         String?
  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  registrationId String        @db.ObjectId
  registration   Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("payments")
}

model GuestPayment {
  id                    String              @id @default(auto()) @map("_id") @db.ObjectId
  amount                String
  transactionId         String              @unique
  provider              String?
  status                PaymentStatus       @default(PENDING)

  guestRegistrationId   String              @db.ObjectId
  guestRegistration     GuestRegistration   @relation(fields: [guestRegistrationId], references: [id], onDelete: Cascade)

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@map("guest_payments")
}

model GuestRegistration {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  phone     String
  Marks        Int?             @default(0) 
  eventId   String     @db.ObjectId
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status    StatusType @default(PENDING)
  isPassed  Boolean?    

  appliedAt DateTime   @default(now())
  metadata  Json?                    // BCC extra fields
  payments  GuestPayment[]           // Guest payment আলাদা

  @@map("guest_registrations")
}


model Committee {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  session   String  @unique  // যেমন: "2026-27"
  isCurrent Boolean   @default(false)
  createdAt DateTime @default(now())
  members   CommitteeMember[]
}

model CommitteeMember {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId

  designation String    
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   
  
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  committeeId String   
  createdAt DateTime @default(now())

   @@unique([userId, committeeId])
}




enum CouponType {
  GLOBAL          // সব event এ চলবে
  EVENT_SPECIFIC  // নির্দিষ্ট event এর জন্য
}

enum DiscountType {
  FIXED      // নির্দিষ্ট টাকা, যেমন 20 BDT
  PERCENT    // শতাংশ, যেমন 50%
  FREE       // 100% free
}

model Coupon {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  code         String       @unique
  couponType   CouponType   @default(GLOBAL)
  discountType DiscountType @default(FIXED)
  discount     Int          @default(0)   // FIXED হলে টাকা, PERCENT হলে %
  memberOnly   Boolean      @default(false) // true হলে শুধু member use করতে পারবে
  maxUses      Int          @default(1)
  usedCount    Int          @default(0)
  isActive     Boolean      @default(true)
  expiresAt    DateTime?
  eventId      String?      @db.ObjectId
  event        Event?       @relation(fields: [eventId], references: [id])
  createdAt    DateTime     @default(now())
  
    usages    CouponUsage[]
  @@map("coupons")
}


model CouponUsage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  couponId  String   @db.ObjectId
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  
  userId    String?
  email     String?
  
  usedAt    DateTime @default(now())

  @@unique([couponId, userId])  
  @@unique([couponId, email])  
  @@map("coupon_usages")
}


model Certificate {
 id        String   @id @default(auto()) @map("_id") @db.ObjectId
  certId          String   @unique
  studentName     String
  EventsName        String   
  phoneNumber       String?
  email             String?
  passedWithMerit   Boolean  @default(false)
  
  isRevoked       Boolean  @default(false) 
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("certificates")
}

model Myuser {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  email String
}